# ============================================================
# DevOps Infrastructure — Root .env.example
# Copy ke .env dan isi dengan nilai yang sesuai
# ============================================================

# ── Global ────────────────────────────────────────────────────
DOMAIN=your-domain.com
TIMEZONE=Asia/Jakarta
ENVIRONMENT=production

# ── Git ───────────────────────────────────────────────────────
GIT_EMAIL=you@example.com
GIT_NAME="Your Name"
GIT_REPO=git@github.com:your-org/infra-light.git
GIT_BRANCH=dev
INFRA_DIR=/opt/infra-light

# ── PostgreSQL ────────────────────────────────────────────────
PG_VERSION=17
PG_IMAGE=postgres-all:latest
PG_CONTAINER_NAME=postgres-all
PG_PORT=5432
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=CHANGE_ME
PG_DATABASE=postgres
PG_APP_USER=appuser
PG_APP_PASSWORD=CHANGE_ME
PG_APP_DB=appdb
PG_SHARED_BUFFERS=1GB
PG_EFFECTIVE_CACHE_SIZE=3GB
PG_WORK_MEM=64MB
PG_MAINTENANCE_WORK_MEM=256MB
PG_MAX_CONNECTIONS=500
PG_MEMORY_LIMIT=4G
PG_MEMORY_RESERVATION=512M
PG_DATA_SIZE=20Gi

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_VERSION=8.4
MYSQL_CONTAINER_NAME=mysql-all
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=CHANGE_ME
MYSQL_HOST=127.0.0.1
MYSQL_MEMORY_LIMIT=2G
MYSQL_MEMORY_RESERVATION=256M
MYSQL_DATA_SIZE=10Gi

# ── Observability ─────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_PORT=3000
GRAFANA_PLUGINS=grafana-pyroscope-app
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ANONYMOUS_ROLE=Admin
GRAFANA_FEATURE_TOGGLES=accessControlOnCall,traceToMetrics,traceToProfiles,traceQLStreaming,correlations
GRAFANA_DATA_SIZE=5Gi

VM_PORT=8428
VM_RETENTION=30d
VM_DATA_SIZE=10Gi

LOKI_PORT=3100
LOKI_RETENTION=30d
LOKI_DATA_SIZE=10Gi

TEMPO_PORT=3200
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318
TEMPO_RETENTION=24h
TEMPO_DATA_SIZE=10Gi

PYROSCOPE_PORT=4040
PYROSCOPE_RETENTION=720h
PYROSCOPE_DATA_SIZE=5Gi

ALLOY_PORT=12345
ALLOY_LOKI_RECEIVER_PORT=3500

# ── K3s ───────────────────────────────────────────────────────
K3S_TOKEN=CHANGE_ME
K3S_VERSION=v1.31.5+k3s1
K3S_FLANNEL_IFACE=tailscale0
K3S_DISABLE_COMPONENTS=traefik,servicelb

# ── Ingress ───────────────────────────────────────────────────
INGRESS_NGINX_VERSION=4.12.1
INGRESS_HTTP_PORT=80
INGRESS_HTTPS_PORT=443
INGRESS_PROXY_BODY_SIZE=100m
INGRESS_PROXY_BUFFER_SIZE=16k
INGRESS_CLIENT_MAX_BODY_SIZE=100m

# ── Cert-Manager ──────────────────────────────────────────────
CERT_MANAGER_VERSION=v1.17.1
LETSENCRYPT_EMAIL=you@example.com

# ── Cloudflare ────────────────────────────────────────────────
CF_TUNNEL_MODE=token
CF_TUNNEL_TOKEN=CHANGE_ME

# ── Tailscale ─────────────────────────────────────────────────
TAILSCALE_VERSION=stable
TAILSCALE_AUTHKEY=CHANGE_ME
TAILSCALE_ARGS=--accept-routes

# ── K8s Resources ─────────────────────────────────────────────
K8S_REQUESTS_MEMORY=128Mi
K8S_REQUESTS_CPU=100m
K8S_LIMITS_MEMORY=512Mi
K8S_LIMITS_CPU=500m

# ── MCP Toolbox ───────────────────────────────────────────────
TOOLBOX_VERSION=1.4.0

# ── SSH ───────────────────────────────────────────────────────
SSH_KEY_TYPE=rsa
SSH_KEY_BITS=4096
SSH_KEY_PATH=$HOME/.ssh/id_rsa
